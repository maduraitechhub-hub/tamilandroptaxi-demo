# Hostinger (or your provider) SMTP — use the mailbox that sends mail (often hello@tamilandroptaxi.com)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
# Use false for port 587 (STARTTLS)
SMTP_SECURE=true
SMTP_USER=hello@tamilandroptaxi.com
SMTP_PASS=your-mailbox-password

# Recipient (defaults to hello@tamilandroptaxi.com if omitted)
MAIL_TO=hello@tamilandroptaxi.com

# From header (defaults to TamilNadu Drop Taxi <SMTP_USER>)
# MAIL_FROM=TamilNadu Drop Taxi <hello@tamilandroptaxi.com>

# Optional: public site URL for metadata (see lib/site.js)
# NEXT_PUBLIC_SITE_URL=https://tamilandroptaxi.com

# Google Maps — Places Autocomplete + fare distance (Maps JavaScript API, Places API (New), Routes API)
# Enable in Google Cloud: Maps JavaScript API, Places API (New), Routes API
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyB-pABxQh-4EkKYdO5P5TCblgdIwWJ-MuU
GOOGLE_MAPS_API_KEY=AIzaSyCBhwqIls5qkJd4rcH8QHztfXY9WadT1P8
# Optional server-only key (falls back to NEXT_PUBLIC_GOOGLE_MAPS_API_KEY):
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key
